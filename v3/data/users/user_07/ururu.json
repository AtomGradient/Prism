  },
  {
    "date": "2026-01-20",
    "mood_score": 0.4,
    "primary_emotion": "疲惫",
    "stress_level": 8,
    "sleep_hours": 4.0,
    "sleep_time": "08:30",
    "wake_time": "12:30",
    "journal_keywords": [
      "连续夜班",
      "第一天"
    ],
    "journal_snippet": "第一个连续夜班。还扛得住，但已经有点恍惚了。"
  },
  {
    "date": "2026-01-21",
    "mood_score": 0.3,
    "primary_emotion": "疲惫",
    "stress_level": 9,
    "sleep_hours": 3.0,
    "sleep_time": "09:00",
    "wake_time": "12:00",
    "journal_keywords": [
      "连续夜班",
      "第二天",
      "恍惚"
    ],
    "journal_snippet": "第二个夜班。脑子开始不清楚了，看医嘱的时候字都在跳。中午只睡了三小时又要上班。"
  },
  {
    "date": "2026-01-22",
    "mood_score": 0.1,
    "primary_emotion": "恐惧",
    "stress_level": 10,
    "sleep_hours": 1.5,
    "sleep_time": "10:00",
    "wake_time": "11:30",
    "journal_keywords": [
      "医疗事故",
      "开错药",
      "ICU",
      "转科"
    ],
    "journal_snippet": "完了。我开错了剂量。万古霉素给了双倍。患者肾功能急转直下，转ICU了。主任的脸色我这辈子忘不了。我怎么会犯这种错误。我对不起那个患者。我的手一直在抖。"
  },
  {
    "date": "2026-01-23",
    "mood_score": 0.08,
    "primary_emotion": "恐惧",
    "stress_level": 10,
    "sleep_hours": 0.5,
    "sleep_time": "05:00",
    "wake_time": "05:30",
    "journal_keywords": [
      "失眠",
      "停职",
      "调查"
    ],
    "journal_snippet": "一夜没睡。早上接到通知停职接受调查。护士长的眼神让我想死。患者家属在走廊哭，我不敢走出值班室。"
  },
  {
    "date": "2026-01-24",
    "mood_score": 0.05,
    "primary_emotion": "绝望",
    "stress_level": 10,
    "sleep_hours": 2.0,
    "sleep_time": "04:00",
    "wake_time": "06:00",
    "journal_keywords": [
      "调查",
      "写报告",
      "内疚"
    ],
    "journal_snippet": "要写事故报告。手在抖，写了改，改了写。我反复回想那个晚上，如果我再仔细看一眼医嘱……如果我不是那么困……"
  },
  {
    "date": "2026-01-25",
    "mood_score": 0.07,
    "primary_emotion": "自责",
    "stress_level": 10,
    "sleep_hours": 2.5,
    "sleep_time": "03:00",
    "wake_time": "05:30",
    "journal_keywords": [
      "自责",
      "患者情况",
      "打听"
    ],
    "journal_snippet": "偷偷问了ICU的同事，患者暂时脱离危险了，但肾功能指标还是很差。都是我的错。我配当医生吗？"
  },
  {
    "date": "2026-01-26",
    "mood_score": 0.1,
    "primary_emotion": "内疚",
    "stress_level": 10,
    "sleep_hours": 3.0,
    "sleep_time": "02:00",
    "wake_time": "05:00",
    "journal_keywords": [
      "内疚",
      "睡不着",
      "噩梦"
    ],
    "journal_snippet": "终于睡着了两三个小时，但梦到患者在ICU的样子就惊醒了。女朋友打电话来，我什么都说不出口。她问我怎么了，我说没事。"
  },
  {
    "date": "2026-01-27",
    "mood_score": 0.12,
    "primary_emotion": "内疚",
    "stress_level": 9,
    "sleep_hours": 3.5,
    "sleep_time": "02:30",
    "wake_time": "06:00",
    "journal_keywords": [
      "安眠药",
      "失眠",
      "医疗事故法"
    ],
    "journal_snippet": "让同事帮开了安眠药。吃了以后能睡几个小时了，但醒来的瞬间就想起那件事，比不睡还难受。开始查医疗事故相关的法律。"
  },
  {
    "date": "2026-01-28",
    "mood_score": 0.13,
    "primary_emotion": "焦虑",
    "stress_level": 9,
    "sleep_hours": 4.0,
    "sleep_time": "01:00",
    "wake_time": "05:00",
    "journal_keywords": [
      "法律",
      "处分",
      "前途"
    ],
    "journal_snippet": "查了一天的医疗事故处理条例。最坏的情况是吊销执照。天塌了。这六年的书、三年的规培、无数个夜班……可能全没了。"
  },
  {
    "date": "2026-01-29",
    "mood_score": 0.15,
    "primary_emotion": "麻木",
    "stress_level": 9,
    "sleep_hours": 3.5,
    "sleep_time": "02:00",
    "wake_time": "05:30",
    "journal_keywords": [
      "麻木",
      "不想动"
    ],
    "journal_snippet": "在家躺了一天。不想吃饭不想动不想看手机。把所有医学群都设了免打扰。妈妈打电话来我装作一切正常。"
  },
  {
    "date": "2026-01-30",
    "mood_score": 0.18,
    "primary_emotion": "沮丧",
    "stress_level": 9,
    "sleep_hours": 4.0,
    "sleep_time": "01:00",
    "wake_time": "05:00",
    "journal_keywords": [
      "患者好转",
      "一点点安慰"
    ],
    "journal_snippet": "ICU同事说患者肾功能在恢复了，应该能转出ICU。稍微松了一口气，但内疚感没有减少。"
  },
  {
    "date": "2026-01-31",
    "mood_score": 0.2,
    "primary_emotion": "焦虑",
    "stress_level": 9,
    "sleep_hours": 4.0,
    "sleep_time": "01:30",
    "wake_time": "05:30",
    "journal_keywords": [
      "等结果",
      "调查结论"
    ],
    "journal_snippet": "明天出调查结论。今晚肯定又睡不着了。如果是严重处分怎么办？如果吊销执照怎么办？我这辈子就完了。"
  },
  {
    "date": "2026-02-01",
    "mood_score": 0.22,
    "primary_emotion": "焦虑",
    "stress_level": 9,
    "sleep_hours": 2.0,
    "sleep_time": "04:00",
    "wake_time": "06:00",
    "journal_keywords": [
      "正式警告",
      "保留执照",
      "劫后余生"
    ],
    "journal_snippet": "调查结论出来了：正式书面警告，记入档案，但保留执照。科主任谈话时说'年轻人要引以为戒'。我应该感到庆幸，但我只感到空洞。走出办公室的时候腿是软的。"
  },
  {
    "date": "2026-02-02",
    "mood_score": 0.2,
    "primary_emotion": "紧张",
    "stress_level": 9,
    "sleep_hours": 3.0,
    "sleep_time": "02:00",
    "wake_time": "05:00",
    "journal_keywords": [
      "回科室",
      "同事眼光",
      "恐惧"
    ],
    "journal_snippet": "第一天回科室。感觉所有人都在看我，护士站的对话一看到我就停了。开医嘱的时候手一直在抖，反复核对了五六遍才敢签字。"
  },
  {
    "date": "2026-02-03",
    "mood_score": 0.18,
    "primary_emotion": "紧张",
    "stress_level": 9,
    "sleep_hours": 3.5,
    "sleep_time": "01:00",
    "wake_time": "04:30",
    "journal_keywords": [
      "不敢开医嘱",
      "PTSD"
    ],
    "journal_snippet": "开每一条医嘱都像在拆炸弹。万古霉素这三个字我现在看到就想吐。手抖的问题越来越严重了。"
  },
  {
    "date": "2026-02-04",
    "mood_score": 0.22,
    "primary_emotion": "沮丧",
    "stress_level": 8,
    "sleep_hours": 4.0,
    "sleep_time": "01:00",
    "wake_time": "05:00",
    "journal_keywords": [
      "女朋友",
      "争吵",
      "不理解"
    ],
    "journal_snippet": "和女朋友吵架了。她说我整个人变了，每天阴沉沉的什么都不说。我说我没事。她说'你从来不跟我说真话'。我该怎么说？说我差点害死一个人？"
  },
  {
    "date": "2026-02-05",
    "mood_score": 0.12,
    "primary_emotion": "绝望",
    "stress_level": 10,
    "sleep_hours": 1.0,
    "sleep_time": "04:00",
    "wake_time": "05:00",
    "journal_keywords": [
      "分手",
      "女朋友",
      "崩溃"
    ],
    "journal_snippet": "她提分手了。在西餐厅。她说她也很痛苦，但她帮不了一个不愿意打开自己的人。我看着她哭，什么都说不出来。三年。就这样结束了。我打车回家，在车上哭了一路。司机什么都没说。"
  },
  {
    "date": "2026-02-06",
    "mood_score": 0.1,
    "primary_emotion": "绝望",
    "stress_level": 10,
    "sleep_hours": 2.0,
    "sleep_time": "03:00",
    "wake_time": "05:00",
    "journal_keywords": [
      "喝酒",
      "一个人",
      "酒吧"
    ],
    "journal_snippet": "请了一天假。去酒吧坐了一晚上。以前从不喝酒的人现在觉得酒精是唯一能让脑子安静下来的东西。想给她发消息，打了删，删了打。最后什么都没发。"
  },
  {
    "date": "2026-02-07",
    "mood_score": 0.15,
    "primary_emotion": "麻木",
    "stress_level": 9,
    "sleep_hours": 3.0,
    "sleep_time": "02:00",
    "wake_time": "05:00",
    "journal_keywords": [
      "宿醉",
      "上班",
      "行尸走肉"
    ],
    "journal_snippet": "宿醉去上班。主任看了我一眼什么都没说。我像个机器人一样查房、写病历、开医嘱。回到家就躺着发呆。"
  },
  {
    "date": "2026-02-08",
    "mood_score": 0.17,
    "primary_emotion": "沮丧",
    "stress_level": 8,
    "sleep_hours": 3.5,
    "sleep_time": "02:00",
    "wake_time": "05:00",
    "journal_keywords": [
      "失眠",
      "冲动消费"
    ],
    "journal_snippet": "又失眠了。半夜三点刷淘宝，买了一堆不需要的东西。买完的瞬间觉得好了一点，然后更空虚。"
  },
  {
    "date": "2026-02-09",
