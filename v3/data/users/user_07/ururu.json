    "primary_emotion": "焦虑",
    "stress_level": 8,
    "sleep_hours": 3.9,
    "sleep_time": "01:00",
    "wake_time": "05:00",
    "journal_keywords": [
      "失眠",
      "冲动消费"
    ],
    "journal_snippet": "晚上一个人在家实在受不了安静，开了外卖吃了一大堆垃圾食品。吃完又后悔。循环往复。"
  },
  {
    "date": "2026-02-11",
